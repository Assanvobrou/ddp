# ── DDP — Variables d'environnement ─────────────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs

# Django
DJANGO_SECRET_KEY=changez-cette-cle-secrete-en-production-min-50-caracteres
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost 127.0.0.1

# ── Base de données PostgreSQL (obligatoire — dev et prod) ────────────────────
# Créer la base avant de lancer :
#   psql -U postgres -c "CREATE USER ddp_user WITH PASSWORD 'votre_mdp';"
#   psql -U postgres -c "CREATE DATABASE ddp_db OWNER ddp_user;"
#   psql -U postgres -c "GRANT ALL PRIVILEGES ON DATABASE ddp_db TO ddp_user;"
DB_NAME=ddp_db
DB_USER=ddp_user
DB_PASSWORD=votre_mot_de_passe
DB_HOST=localhost
DB_PORT=5432

# CORS — origines autorisées pour le frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173 http://localhost:3000
